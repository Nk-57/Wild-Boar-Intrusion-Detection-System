#include <SPI.h>
#include <LoRa.h>

#define PIR_PIN 13
#define LED_PIN 12
#define BUZZER_PIN 14

void setup() {

  Serial.begin(115200);

  pinMode(PIR_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  // LoRa Setup
  LoRa.setPins(5, 17, 16); // NSS, RST, DIO0

  if (!LoRa.begin(433E6)) {
    Serial.println("LoRa Init Failed");
    while (1);
  }

  Serial.println("Village Node Ready");
}

void loop() {

  int motion = digitalRead(PIR_PIN);

  if (motion == HIGH) {

    Serial.println("Animal Detected");

    activateDeterrent();

    sendAlert();

    delay(5000);
  }

  delay(200);
}

void activateDeterrent() {

  int randomDelay = random(2000, 6000);

  digitalWrite(LED_PIN, HIGH);
  digitalWrite(BUZZER_PIN, HIGH);

  delay(randomDelay);

  digitalWrite(LED_PIN, LOW);
  digitalWrite(BUZZER_PIN, LOW);
}

void sendAlert() {

  LoRa.beginPacket();
  LoRa.print("BOAR_ALERT");
  LoRa.endPacket();

  Serial.println("Alert Sent");
}
